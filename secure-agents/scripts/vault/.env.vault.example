#!/usr/bin/env bash
#
# Vault Setup Environment Variables
#
# Copy this file to .env.vault and fill in your values:
#   cp .env.vault.example .env.vault
#
# Then source it before running vault-setup.sh:
#   source .env.vault
#   ./scripts/vault-setup.sh
#

#############################################
# Vault Server Configuration
#############################################

# Vault server address (required)
export VAULT_ADDR="http://localhost:8200"

# Vault authentication token (required)
# Get this from: vault operator init (root token)
# Or: vault login (generates a token)
export VAULT_TOKEN="your-root-token-here"

# Vault namespace (optional, use if running Vault Enterprise)
# export VAULT_NAMESPACE="admin"

#############################################
# MongoDB Configuration
#############################################

# MongoDB connection details
export MONGO_HOST="mongodb"
export MONGO_PORT="27017"

# MongoDB admin credentials (must match docker-compose.yml)
export MONGO_USERNAME="appuser"
export MONGO_PASSWORD="changeme123"

# MongoDB database name (default: test, matches init-mongo.js)
export MONGO_DATABASE="products_catalog"

#############################################
# IBM Verify OIDC Configuration
#############################################

# IBM Verify tenant OIDC discovery URL (required)
# Format: https://<TENANT_ID>.verify.ibm.com/oauth2
# Example: https://abc123.verify.ibm.com/oauth2
export OIDC_DISCOVERY_URL="https://<your-tenant>.verify.ibm.com/oauth2"

# OIDC Client ID (optional, leave empty if not using client credentials)
export OIDC_CLIENT_ID=""

# OIDC Client Secret (optional, leave empty if not using client credentials)
export OIDC_CLIENT_SECRET=""

# Bound audiences - the client ID from your agent-app in IBM Verify (required)
# This is the audience claim (aud) that will be validated in JWT tokens
export BOUND_AUDIENCES="<your-agent-app-client-id>"

#############################################
# Audit Logging Configuration
#############################################

# Path to Vault audit log sink
# Use "stdout" for pod/container deployments so logs go to the container log stream.
# Use a writable file path only if the Vault server process can write there.
export VAULT_AUDIT_LOG_PATH="stdout"

#############################################
# Optional: Advanced Configuration
#############################################

# Enable verbose OIDC logging for debugging
export VAULT_VERBOSE_OIDC_LOGGING="true"

# Database connection name in Vault (default: docdb)
export VAULT_DB_CONNECTION_NAME="docdb"

# Default TTL for database credentials (default: 1h)
export VAULT_DB_DEFAULT_TTL="1h"

# Maximum TTL for database credentials (default: 24h)
export VAULT_DB_MAX_TTL="24h"

#############################################
# Example Values for Local Development
#############################################

# Uncomment and modify these for local testing:
# export VAULT_ADDR="http://localhost:8200"
# export VAULT_TOKEN="hvs.CAESIJ..."
# export MONGO_HOST="mongodb"
# export MONGO_PORT="27017"
# export MONGO_USERNAME="admin"
# export MONGO_PASSWORD="secret"
# export OIDC_DISCOVERY_URL="https://your-tenant.verify.ibm.com/oauth2"
# export BOUND_AUDIENCES="your-client-id"

#############################################
# Validation
#############################################

# The script will validate that required variables are set
# Required variables:
#   - VAULT_ADDR
#   - VAULT_TOKEN (or authenticated via vault login)
#   - OIDC_DISCOVERY_URL
#   - BOUND_AUDIENCES
#   - MONGO_HOST
#   - MONGO_PORT
#   - MONGO_USERNAME
#   - MONGO_PASSWORD
#!/bin/bash
# =============================================================================
# Environment Variables for Confused Deputy MCP Connection
# =============================================================================
# This file contains all necessary configuration parameters for the
# integration between Watson Orchestrate and the MCP (Model Context Protocol) Server.
# 
# IMPORTANT: This is an example file. Copy this file to .env.sh
# and replace all placeholder values with your actual credentials.
# =============================================================================

# -----------------------------------------------------------------------------
# Application Identification
# -----------------------------------------------------------------------------
# Name of the MCP connection in Watson Orchestrate
APP_ID=Confused-Deputy-MCP-Connection

# -----------------------------------------------------------------------------
# Watson Orchestrate Service Configuration
# -----------------------------------------------------------------------------
# URL of the Watson Orchestrate service instance
# Format: https://api.<region>.dl.watson-orchestrate.ibm.com/instances/<instance-id>
export SERVICE_INSTANCE="https://api.<region>.dl.watson-orchestrate.ibm.com/instances/<your-instance-id>"

# API key for accessing Watson Orchestrate
# This is generated in the IBM Cloud Console
export API_KEY="<your-api-key>"

# -----------------------------------------------------------------------------
# Agent App OAuth2 Credentials
# -----------------------------------------------------------------------------
# These credentials are used for authenticating the agent client
# Client secret for the agent application
export agent_app_secret='<your-agent-app-secret>'

# Client ID for the agent application (UUID format)
export agent_app_client_id='<your-agent-app-client-id>'

# -----------------------------------------------------------------------------
# Web App OAuth2 Credentials
# -----------------------------------------------------------------------------
# These credentials are used for the web application
# Client secret for the web application
# This is needed to obtain an access token for the Watson Orchestrate service
export app_secret='<web-app-secret>'

# Client ID for the main application (UUID format)
export app_client_id='<web-app-client-id>'

# -----------------------------------------------------------------------------
# OAuth2 Server Configuration
# -----------------------------------------------------------------------------
# Base URL of the OAuth2 server (IBM Verify)
export server_url='https://<your-tenant>.verify.ibm.com/oauth2'

# Token endpoint for OAuth2 token requests
export token_url='https://<your-tenant>.verify.ibm.com/oauth2/token'

# -----------------------------------------------------------------------------
# OAuth2 Token Exchange Parameters
# -----------------------------------------------------------------------------
# Grant type for token exchange (RFC 8693)
# This special grant type enables exchanging one token for another
export grant_type='urn:ietf:params:oauth:grant-type:token-exchange'

# Subject token - The original access token to be exchanged (optional)
export subject_token='<your-jwt-access-token>'

# OAuth2 scopes - Defines the requested permissions
# openid: Enables OpenID Connect authentication
# profile: Access to user profile information
# email: Access to user's email address
export scope='openid profile email'

# -----------------------------------------------------------------------------
# Token Exchange Specifications
# -----------------------------------------------------------------------------
# Purpose of the requested token
# 'on_behalf_of' means the new token will be used on behalf of the original user
export requested_token_use='on_behalf_of'

# Type of the subject token (according to RFC 8693)
# Indicates that the provided token is an access token
export subject_token_type='urn:ietf:params:oauth:token-type:access_token'

# =============================================================================
# End of Configuration
# =============================================================================

# Made with Bob

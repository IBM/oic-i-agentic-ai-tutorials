# Deployment Flavor
# Valid options: local-auth, backend-only, oauth-proxy, backend-only-no-db, local-auth-custom-ui, oauth-proxy-custom-ui
# Default: local-auth (full stack with local authentication)
CEN_FLAVOR=local-auth

# Environment: local, staging, production
ENVIRONMENT=local

PROJECT_NAME="Full Stack FastAPI Project"

# Backend
BACKEND_CORS_ORIGINS="http://localhost,http://localhost:5173,http://localhost:5174,https://localhost,https://localhost:5173,https://localhost:5174"
SECRET_KEY=changethis

# Postgres
POSTGRES_SERVER=localhost
POSTGRES_PORT=5432
POSTGRES_DB=app
POSTGRES_USER=postgres
POSTGRES_PASSWORD=changethis

# IBM Verify OAuth Configuration
IBM_VERIFY_CLIENT_ID=your-client-id
IBM_VERIFY_CLIENT_SECRET=your-client-secret
IBM_VERIFY_TENANT_ID=your-tenant.verify.ibm.com
IBM_VERIFY_SCOPE=openid profile email
IBM_VERIFY_REDIRECT_URI=http://localhost:5173/oauth2callback

# Watson Orchestrate Configuration
# These are shared between frontend (VITE_*) and backend
VITE_WXO_HOST_URL=https://us-south.watson-orchestrate.cloud.ibm.com
VITE_WXO_ORCHESTRATION_ID=your-orchestration-id
VITE_WXO_AGENT_ID=your-agent-id
VITE_WXO_AGENT_ENVIRONMENT_ID=your-agent-environment-id
VITE_WXO_DEPLOYMENT_PLATFORM=ibmcloud
VITE_WXO_CRN=your-crn
VITE_WXO_TENANT_ID=your-tenant-id

# Watson Orchestrate RSA Keys (base64 encoded PEM format)
# To generate base64 from PEM file: base64 -i keyfile.pem | tr -d '\n'
# Or run: ./local/encode-keys.sh

# YOUR private key - used to SIGN JWT tokens sent to Watson Orchestrate
JWT_PRIVATE_KEY_BASE64=your-base64-encoded-private-key

# WATSON ORCHESTRATE's public key - used to ENCRYPT user payload that WXO will decrypt
WXO_PUBLIC_KEY_BASE64=your-base64-encoded-wxo-public-key
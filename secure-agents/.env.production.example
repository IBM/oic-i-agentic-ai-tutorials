# See .docs/oc-deployment.md for detailed deployment documentation
# See scripts/README.md for technical details
# Variables prefixed with "_" won't be available as environment variables to the application

################################################################
# Common
################################################################

# One of: local-auth, backend-only, oauth-proxy, backend-only-no-db, local-auth-custom-ui, oauth-proxy-custom-ui, confused-deputy
_CEN_FLAVOR=confused-deputy

# Application Identity
PROJECT_NAME=confused-deputy
ENVIRONMENT=production

BACKEND_CORS_ORIGINS=

# Confused Deputy Flavor Variables (required for confused-deputy flavor)
# API Key for backend authentication
API_KEY=changethis-min-16-chars-powerof2

# Custom Variables (Optional - will be available to the backend)
# CUSTOM_VAR=custom-value

# IBM Verify OAuth Configuration
IBM_VERIFY_CLIENT_ID=your-client-id
IBM_VERIFY_CLIENT_SECRET=your-client-secret
IBM_VERIFY_TENANT_ID=your-tenant.verify.ibm.com
IBM_VERIFY_SCOPE=openid profile email
IBM_VERIFY_REDIRECT_URI=<Route-To-Your-Frontend>/oauth2callback

# Watson Orchestrate Configuration
# These are shared between frontend (VITE_*) and backend

VITE_WXO_HOST_URL=https://us-south.watson-orchestrate.cloud.ibm.com
VITE_WXO_ORCHESTRATION_ID=your-orchestration-id
VITE_WXO_AGENT_ID=your-agent-id
VITE_WXO_AGENT_ENVIRONMENT_ID=your-agent-environment-id
VITE_WXO_DEPLOYMENT_PLATFORM=ibmcloud
VITE_WXO_CRN=your-crn
VITE_WXO_TENANT_ID=your-tenant-id

JWT_PRIVATE_KEY_BASE64="...."
WXO_PUBLIC_KEY_BASE64="..."


# MCP Server Configuration
JWKS_URI=https://<your-tenant>.verify.ibm.com/oauth2/jwks
JWT_ISSUER=https:///<your-tenant>.verify.ibm.com/oauth2
JWT_AUDIENCE=<AGENT-APP-CLIENT-ID>
VAULT_ADDR=https://vault
LOG_LEVEL=info
VAULT_CACHE_ENABLED=false

# MongoDB Configuration (for MCP Server)
DB_HOST=mongodb
DB_PORT=27017
DB_NAME=products_catalog
COLLECTION_NAME=products

# MongoDB Deployment Configuration (Optional - for OpenShift deployment)
# Uncomment and configure these if you want to deploy MongoDB to OpenShift
MONGO_DB=app
MONGO_USER=appuser
MONGO_PASSWORD=changeme123


# MCP Server Configuration
SERVER_HOST=0.0.0.0
SERVER_PORT=8001
SERVER_NAME=products-mcp

# Application Settings
MAX_RESULTS=100

################################################################
# OpenShift Deployment
################################################################

_APP_NAME=confused-deputy-app
_GIT_SSH_URL=git@github.ibm.com:client-engineering-dach/confused-deputy.git
# OPTIONAL but recommended (check .docs/oc-deployment.md for details)
_GITHUB_TOKEN=
_GITHUB_HOST=github.ibm.com
# OPTIONAL (deploy a specific branch)
_DEPLOYMENT_BRANCH_FILTER=

################################################################
# Code Engine Deployment
################################################################

# VITE_API_URL=

# _IAM_API_KEY=<your-api-key>
# _IBM_CLOUD_RESOURCE_GROUP=Default
# _IBM_CLOUD_REGION=eu-de
# _IBM_CLOUD_ACCOUNT_NAME="IBM PoC - Your POC Account"

# _CE_PROJECT_NAME=<project-name> (max 20 chars)
# _CR_REGISTRY=de.icr.io
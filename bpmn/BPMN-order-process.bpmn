<?xml version="1.0" encoding="UTF-8"?>
<bpmn:definitions xmlns:bpmn="http://www.omg.org/spec/BPMN/20100524/MODEL" 
                  xmlns:bpmndi="http://www.omg.org/spec/BPMN/20100524/DI" 
                  xmlns:dc="http://www.omg.org/spec/DD/20100524/DC" 
                  xmlns:di="http://www.omg.org/spec/DD/20100524/DI" 
                  id="Definitions_1" 
                  targetNamespace="http://bpmn.io/schema/bpmn">
  
  <bpmn:process id="OrderProcess" name="Order Processing Workflow" isExecutable="true">
    
    <bpmn:startEvent id="StartEvent_1" name="Order Received">
      <bpmn:outgoing>Flow_1</bpmn:outgoing>
    </bpmn:startEvent>
    
    <bpmn:task id="Task_ValidateOrder" name="Validate Order">
      <bpmn:incoming>Flow_1</bpmn:incoming>
      <bpmn:outgoing>Flow_2</bpmn:outgoing>
    </bpmn:task>
    
    <bpmn:exclusiveGateway id="Gateway_CheckInventory" name="Items in Stock?">
      <bpmn:incoming>Flow_2</bpmn:incoming>
      <bpmn:outgoing>Flow_3_Yes</bpmn:outgoing>
      <bpmn:outgoing>Flow_3_No</bpmn:outgoing>
    </bpmn:exclusiveGateway>
    
    <bpmn:serviceTask id="Task_ProcessPayment" name="Process Payment">
      <bpmn:incoming>Flow_3_Yes</bpmn:incoming>
      <bpmn:outgoing>Flow_4</bpmn:outgoing>
    </bpmn:serviceTask>
    
    <bpmn:userTask id="Task_NotifyOutOfStock" name="Notify Customer">
      <bpmn:incoming>Flow_3_No</bpmn:incoming>
      <bpmn:outgoing>Flow_5</bpmn:outgoing>
    </bpmn:userTask>
    
    <bpmn:task id="Task_ShipOrder" name="Ship Order">
      <bpmn:incoming>Flow_4</bpmn:incoming>
      <bpmn:outgoing>Flow_6</bpmn:outgoing>
    </bpmn:task>
    
    <bpmn:sendTask id="Task_SendConfirmation" name="Send Confirmation">
      <bpmn:incoming>Flow_6</bpmn:incoming>
      <bpmn:outgoing>Flow_7</bpmn:outgoing>
    </bpmn:sendTask>
    
    <bpmn:endEvent id="EndEvent_Complete" name="Order Complete">
      <bpmn:incoming>Flow_7</bpmn:incoming>
    </bpmn:endEvent>
    
    <bpmn:endEvent id="EndEvent_Cancelled" name="Order Cancelled">
      <bpmn:incoming>Flow_5</bpmn:incoming>
    </bpmn:endEvent>
    
    <bpmn:sequenceFlow id="Flow_1" sourceRef="StartEvent_1" targetRef="Task_ValidateOrder" />
    <bpmn:sequenceFlow id="Flow_2" sourceRef="Task_ValidateOrder" targetRef="Gateway_CheckInventory" />
    <bpmn:sequenceFlow id="Flow_3_Yes" name="Yes" sourceRef="Gateway_CheckInventory" targetRef="Task_ProcessPayment" />
    <bpmn:sequenceFlow id="Flow_3_No" name="No" sourceRef="Gateway_CheckInventory" targetRef="Task_NotifyOutOfStock" />
    <bpmn:sequenceFlow id="Flow_4" sourceRef="Task_ProcessPayment" targetRef="Task_ShipOrder" />
    <bpmn:sequenceFlow id="Flow_5" sourceRef="Task_NotifyOutOfStock" targetRef="EndEvent_Cancelled" />
    <bpmn:sequenceFlow id="Flow_6" sourceRef="Task_ShipOrder" targetRef="Task_SendConfirmation" />
    <bpmn:sequenceFlow id="Flow_7" sourceRef="Task_SendConfirmation" targetRef="EndEvent_Complete" />
    
  </bpmn:process>
  
</bpmn:definitions>

<!-- Made with Bob -->
